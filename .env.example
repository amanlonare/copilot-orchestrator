# Project Info
PROJECT_NAME=copilot-orchestrator
ENVIRONMENT=development

# API Configuration
PORT=8000
HOST=0.0.0.0

# LLM Configuration
# Get your key at https://platform.openai.com/
# Redis & Persistence
# Local dev: redis://localhost:6379
# Docker compose: redis://redis:6379
REDIS_URL=redis://localhost:6379

# Telemetry: Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Host defaults to https://cloud.langfuse.com
LANGFUSE_HOST=

# Telemetry: OpenTelemetry / Honeycomb
HONEYCOMB_API_KEY=
OTEL_SERVICE_NAME=copilot-orchestrator
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Infrastructure
REDIS_URL=redis://localhost:6379/0

# Data Layer (External)
DATA_LAYER_BASE_URL=http://localhost:8001
DATA_LAYER_API_KEY=your_data_layer_api_key_here

# Logging
LOG_LEVEL=INFO
LOG_FORMAT_JSON=true
